{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/unitedhealthcare/refs/heads/main/json-schema/interoperability-fhir-bundle-schema.json",
  "title": "UnitedHealthcare FHIR Bundle",
  "description": "FHIR R4 Bundle resource containing a collection of FHIR resources for patient access and provider directory",
  "type": "object",
  "properties": {
    "resourceType": {
      "type": "string",
      "enum": [
        "Bundle"
      ],
      "description": "FHIR resource type"
    },
    "id": {
      "type": "string",
      "description": "Bundle ID"
    },
    "type": {
      "type": "string",
      "enum": [
        "searchset",
        "collection",
        "document"
      ],
      "description": "Bundle type"
    },
    "total": {
      "type": "integer",
      "description": "Total matching resources"
    },
    "link": {
      "type": "array",
      "description": "Navigation links",
      "items": {
        "type": "object",
        "properties": {
          "relation": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "entry": {
      "type": "array",
      "description": "Bundle entries",
      "items": {
        "type": "object",
        "properties": {
          "fullUrl": {
            "type": "string"
          },
          "resource": {
            "type": "object"
          },
          "search": {
            "type": "object"
          }
        }
      }
    }
  }
}